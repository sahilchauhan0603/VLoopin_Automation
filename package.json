{
  "name": "loopin-automation",
  "version": "1.0.0",
  "description": "Playwright UI Automation Framework for Loopin – POM & Data-driven",
  "private": true,
  "scripts": {
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "encrypt:password": "node scripts/encrypt-password.js",
    "test:login": "npx playwright test tests/01-login.spec.ts",
    "test:requisition": "npx playwright test tests/03-requisition.spec.ts",
    "test:dashboard": "npx playwright test tests/02-employee-dashboard.spec.ts",
    "test:referrals": "npx playwright test tests/04-referrals.spec.ts",
    "test:ci": "CI=true npx playwright test",
    "test:ci:login": "CI=true npx playwright test tests/01-login.spec.ts",
    "test:ci:dashboard": "CI=true npx playwright test tests/02-employee-dashboard.spec.ts",
    "test:ci:requisition": "CI=true npx playwright test tests/03-requisition.spec.ts",
    "test:ci:referrals": "CI=true npx playwright test tests/04-referrals.spec.ts",
    "report": "npx playwright show-report playwright-report",
    "report:custom": "node -e \"require('fs').existsSync('custom-report/index.html') ? console.log('Open custom-report/index.html in your browser') : console.log('Run tests first to generate custom-report/index.html')\"",
    "install:browsers": "npx playwright install --with-deps chromium msedge",
    "docker:build": "docker build -t loopin-playwright .",
    "docker:test": "node scripts/docker-test.js",
    "clean": "npx rimraf test-results playwright-report custom-report .auth .edge-profile"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@types/node": "latest",
    "@types/speakeasy": "latest",
    "dotenv": "latest",
    "speakeasy": "latest",
    "typescript": "latest"
  }
}
