# Loopin app URL
LOOPIN_BASE_URL=https://vhiredev.z22.web.core.windows.net

# Microsoft (MSAL) credentials for internal login
LOOPIN_USERNAME=your.name@company.com
LOOPIN_PASSWORD=
LOOPIN_PASSWORD_ENCRYPTED=
LOOPIN_PASSWORD_KEY=

# TOTP secret for Microsoft Authenticator MFA (base32-encoded)
LOOPIN_TOTP_SECRET=your-base32-totp-secret

# Test timeout in ms
LOOPIN_TIMEOUT=60000

# Number of retries for failed tests
LOOPIN_RETRIES=2

# Number of Playwright workers running in parallel
LOOPIN_WORKERS=2

# Force a brand-new login each run (ignore saved storage state/profile)
LOOPIN_FORCE_FRESH_LOGIN=false

# Suppress dotenvx terminal logs
DOTENV_QUIET=true
